{
	"name": "@blakron/game",
	"version": "0.2.4",
	"description": "Game extensions for the Blakron engine — Tween, Ease, MovieClip, ScrollView, URLLoader",
	"author": "",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist/**/*"
	],
	"scripts": {
		"build": "tsc --build",
		"dev": "tsc --watch",
		"clean": "rm -rf dist",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@blakron/core": "^0.5.1"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"happy-dom": "^20.8.9",
		"typescript": "^5.6.0",
		"vitest": "^4.1.4"
	},
	"keywords": [
		"blakron",
		"game",
		"tween",
		"movieclip",
		"h5-game",
		"typescript"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/irwinmc/blakron-game.git"
	},
	"packageManager": "pnpm@10.33.0"
}
